# -----------------------------
# OneHaven production environment template
# Safe to commit. Replace placeholders in your deployment platform.
# Never commit real production secrets.
# -----------------------------

ENVIRONMENT=production
LOG_LEVEL=INFO

# Production DB must be managed Postgres/PostGIS.
# Do not use localhost. Do not use the dev password.
DATABASE_URL=postgresql+psycopg2://<user>:<password>@<managed-postgres-host>:5432/<database>

# Public frontend origin only.
FRONTEND_ORIGIN=https://<your-frontend-domain>
CORS_ALLOW_ORIGINS=https://<your-frontend-domain>
CORS_ALLOW_CREDENTIALS=true

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_TIMEOUT_KEEP_ALIVE=5
API_REQUEST_TIMEOUT_SECONDS=30

GZIP_MINIMUM_SIZE=1000

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

NEXT_PUBLIC_API_URL=https://<your-api-domain>

FRED_API_KEY=<set-in-secret-manager>
HUD_USPS_ACCESS_TOKEN=<set-in-secret-manager>
OVERTURE_MAPS_API_KEY=<set-in-secret-manager>
CENSUS_DATA_API_KEY=<optional-set-in-secret-manager>
BLS_API_KEY=<optional-set-in-secret-manager>
