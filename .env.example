# -----------------------------
# OneHaven local Docker environment
# Safe to commit. Do not put real secrets here.
# -----------------------------

# Runtime
ENVIRONMENT=local
LOG_LEVEL=INFO

# Postgres container
POSTGRES_USER=onehaven
POSTGRES_PASSWORD=onehaven_dev_password
POSTGRES_DB=onehaven_market
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Docker API -> Docker Postgres
# This is the URL used inside docker compose. Host is "postgres", not localhost.
DOCKER_DATABASE_URL=postgresql+psycopg2://onehaven:onehaven_dev_password@postgres:5432/onehaven_market
DATABASE_URL=postgresql+psycopg2://onehaven:onehaven_dev_password@postgres:5432/onehaven_market

# Host scripts -> Docker Postgres port mapping
# Use this only for local host-side scripts, pytest, dbt, and pipeline commands.
HOST_DATABASE_URL=postgresql+psycopg2://onehaven:onehaven_dev_password@localhost:5432/onehaven_market

# Backend
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_TIMEOUT_KEEP_ALIVE=5
API_REQUEST_TIMEOUT_SECONDS=30

# CORS
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# Compression
GZIP_MINIMUM_SIZE=1000

# API DB pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Data providers
FRED_API_KEY=replace_with_your_fred_api_key

# Zillow Research source mode
ZILLOW_SOURCE_MODE=local
ZILLOW_ZHVI_LOCAL_PATH=data/import/zillow/zhvi.csv
ZILLOW_ZORI_LOCAL_PATH=data/import/zillow/zori.csv
ZILLOW_ZHVI_URL=replace_with_current_zillow_zhvi_csv_url
ZILLOW_ZORI_URL=replace_with_current_zillow_zori_csv_url

# Redfin Data Center source mode
REDFIN_SOURCE_MODE=local
REDFIN_MARKET_TRACKER_LOCAL_PATH=data/import/redfin/market_tracker.csv
REDFIN_MARKET_TRACKER_URL=replace_with_current_redfin_market_tracker_csv_url

# Census geography
CENSUS_YEAR=2025
CENSUS_STATE_URL=https://www2.census.gov/geo/tiger/GENZ2025/shp/cb_2025_us_state_500k.zip
CENSUS_CBSA_URL=https://www2.census.gov/geo/tiger/TIGER2025/CBSA/tl_2025_us_cbsa.zip

# Census Building Permits Survey
CENSUS_BPS_SOURCE_MODE=local
CENSUS_BPS_STATE_MONTHLY_LOCAL_PATH=data/import/census_building_permits/state_jan_2026.xls
CENSUS_BPS_CBSA_MONTHLY_LOCAL_PATH=data/import/census_building_permits/cbsa_jan_2026.xls
CENSUS_BPS_STATE_ANNUAL_LOCAL_PATH=data/import/census_building_permits/state_annual_2025.xls
CENSUS_BPS_CBSA_ANNUAL_PATH=data/import/census_building_permits/cbsa_annual_2025.xls

# Census ACS Data API
CENSUS_ACS_YEAR=2024
CENSUS_ACS_BASE_URL=https://api.census.gov/data
CENSUS_DATA_API_KEY=

# HUD-USPS ZIP Code Crosswalk API
HUD_USPS_API_BASE_URL=https://www.huduser.gov/hudapi/public/usps
HUD_USPS_ACCESS_TOKEN=replace_with_hud_usps_access_token
HUD_USPS_YEAR=2025
HUD_USPS_QUARTER=4
HUD_USPS_QUERY=All

# BLS LAUS
BLS_API_BASE_URL=https://api.bls.gov/publicAPI/v2/timeseries/data/
BLS_API_KEY=
BLS_LAUS_START_YEAR=2020
BLS_LAUS_END_YEAR=2026

# HMDA Data Browser API
HMDA_API_BASE_URL=https://ffiec.cfpb.gov/v2/data-browser-api/view
HMDA_YEAR=2023
HMDA_GEOGRAPHY_TYPE=states
HMDA_GEOGRAPHY_VALUES=MI
HMDA_ACTIONS_TAKEN=1
HMDA_LOAN_PURPOSES=1
HMDA_LOAN_TYPES=
HMDA_LIEN_STATUSES=

# FEMA National Risk Index
FEMA_NRI_SOURCE_MODE=arcgis
FEMA_NRI_ARCGIS_ITEM_ID=39485e8035d446a5bff03259508ae355
FEMA_NRI_ARCGIS_SERVICE_URL=
FEMA_NRI_ARCGIS_LAYER_ID=0
FEMA_NRI_ARCGIS_PAGE_SIZE=2000
FEMA_NRI_ARCGIS_WHERE=1=1
FEMA_NRI_ARCGIS_OUT_FIELDS=*
FEMA_NRI_VERSION=1.20
FEMA_NRI_RELEASE_LABEL=December 2025

# Overture Maps
OVERTURE_SOURCE_MODE=cloud
OVERTURE_RELEASE=latest
OVERTURE_BBOX=-83.35,42.05,-82.85,42.55
OVERTURE_AREA_SLUG=detroit_metro
OVERTURE_AREA_NAME=Detroit Metro
OVERTURE_TYPES=place
OVERTURE_OUTPUT_FORMAT=geoparquet

OVERTURE_MAPS_API_BASE_URL=https://api.overturemapsapi.com
OVERTURE_MAPS_API_KEY=replace_with_overture_maps_api_key
OVERTURE_MAPS_API_ENDPOINT=places
OVERTURE_MAPS_API_AREA_SLUG=detroit_metro
OVERTURE_MAPS_API_AREA_NAME=Detroit Metro
OVERTURE_MAPS_API_COUNTRY=US
OVERTURE_MAPS_API_LAT=42.3314
OVERTURE_MAPS_API_LNG=-83.0458
OVERTURE_MAPS_API_RADIUS=25000
OVERTURE_MAPS_API_CATEGORIES=cafes,supermarket,restaurant,school,park,hospital,pharmacy,bank
OVERTURE_MAPS_API_BRAND_NAME=
OVERTURE_MAPS_API_LIMIT=5000

# Census Gazetteer
CENSUS_PLACES_LOCAL_PATH=data/import/census/gazetteer/places.txt
CENSUS_ZCTAS_LOCAL_PATH=data/import/census/gazetteer/zctas.txt
